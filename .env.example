# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# API key from https://www.exchangerate-api.com (free tier works for personal use)
EXCHANGE_API_KEY=your_exchangerate_api_key_here

# How often (in minutes) to refresh exchange rates
RATES_REFRESH_MINUTES=60

# Base currency for storage and conversions (ISO 4217, e.g. USD, EUR)
BASE_CURRENCY=USD
